# Core infra
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/expertkb
REDIS_URL=redis://localhost:6379/0
VECTORDB_ENDPOINT=http://localhost:6333

# Config
CONFIG_DIR=./shared/configs

# Object storage
OBJECT_STORAGE_BACKEND=auto
LOCAL_STORAGE_ROOT=.runtime/objects
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=expertkb

# Registry / queue
DOC_REGISTRY_BACKEND=auto
DOC_REGISTRY_PATH=.runtime/registry.json
TASK_QUEUE_BACKEND=auto
REDIS_QUEUE_NAME=document:process

# Search / Qdrant
SEARCH_REPO_BACKEND=auto
VECTORDB_BACKEND=auto
QDRANT_COLLECTION=chunks_v1
QDRANT_VECTOR_NAME=text_embedding
HYBRID_KEYWORD_ENABLED=1
ENABLE_RERANK=1
ENABLE_PG_BM25=0
ENABLE_SIRCHMUNK=0
ENABLE_STRUCTURED_LOOKUP=0
ENABLE_YOUTU_GRAPHRAG=0
SIRCHMUNK_BASE_URL=http://localhost:8091
YOUTU_GRAPHRAG_BASE_URL=http://localhost:8092
SPARSE_SIDECAR_DOCS_ROOT=/data/docs
CHUNK_MIN_CHARS=220
CHUNK_MAX_CHARS=420
CHUNK_OVERLAP_CHARS=80
QUALITY_GATE_MIN_CHARS=100
ENABLE_LANGEXTRACT=0

# API local debug
CORS_ALLOW_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Auth / RBAC
AUTH_ENABLED=false
AUTH_TOKENS_JSON={"admin-token":"system_admin","engineer-token":"bid_engineer","employee-token":"employee"}

# Upload guard
UPLOAD_MAX_MB=50

# LLM (commercial provider)
LLM_PROVIDER=auto
LLM_HTTP_TIMEOUT_S=30
LLM_SYSTEM_PROMPT=You are a factual assistant. Use citations and avoid unsupported claims.

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0.2

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=1024

# Retrieval eval gate
EVAL_MIN_QUERIES=30
EVAL_MIN_HIT10=0.75
EVAL_MIN_MRR=0.45
EVAL_MIN_EVIDENCE_HIT10=0.80
