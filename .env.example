# Core infra
DATABASE_URL=postgresql://postgres:CHANGE_ME_REQUIRED@localhost:5432/expertkb
REDIS_URL=redis://localhost:6379/0
VECTORDB_ENDPOINT=http://localhost:6333

# Config
CONFIG_DIR=./shared/configs

# Object storage
OBJECT_STORAGE_BACKEND=auto
LOCAL_STORAGE_ROOT=.runtime/objects
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
# REQUIRED: change this before deployment
MINIO_SECRET_KEY=CHANGE_ME_REQUIRED
MINIO_BUCKET=expertkb

# Registry / queue
DOC_REGISTRY_BACKEND=auto
DOC_REGISTRY_PATH=.runtime/registry.json
TASK_QUEUE_BACKEND=auto
REDIS_QUEUE_NAME=document:process

# Search / Qdrant
SEARCH_REPO_BACKEND=auto
VECTORDB_BACKEND=auto
QDRANT_COLLECTION=chunks_v1
QDRANT_VECTOR_NAME=text_embedding
QDRANT_ALLOW_RECREATE_ON_DIM_MISMATCH=0
HYBRID_KEYWORD_ENABLED=1
ENABLE_QDRANT_SCROLL_KEYWORD=1
ENABLE_RERANK=1
# P2: PG-BM25 sparse retrieval (requires doc_pages table from migration 0003)
ENABLE_PG_BM25=1
ENABLE_SIRCHMUNK=0
# P2: Structured lookup from assets table
ENABLE_STRUCTURED_LOOKUP=1
ENABLE_YOUTU_GRAPHRAG=0
SIRCHMUNK_BASE_URL=http://sirchmunk:8091
YOUTU_GRAPHRAG_BASE_URL=http://localhost:8092
SPARSE_SIDECAR_DOCS_ROOT=/data/docs
CHUNK_MIN_CHARS=220
CHUNK_MAX_CHARS=420
CHUNK_OVERLAP_CHARS=80
QUALITY_GATE_MIN_CHARS=100
ENABLE_LANGEXTRACT=1
WORKER_LANGEXTRACT_DOC_TYPES=规范规程

# Rate limiting (requests per minute per IP)
RATE_LIMIT_UPLOAD=5/minute
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_SEARCH=60/minute

# API local debug
CORS_ALLOW_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Auth / RBAC
# REQUIRED: set to true in production
AUTH_ENABLED=true
# REQUIRED: JSON map of token->role; roles: system_admin, bid_engineer, employee
AUTH_TOKENS_JSON={"CHANGE_ME_ADMIN_TOKEN":"system_admin","CHANGE_ME_ENG_TOKEN":"bid_engineer"}

# Upload guard
UPLOAD_MAX_MB=50

# Logging
LOG_LEVEL=INFO
# LOG_FORMAT=console  # set to "console" for local dev pretty-print

# App environment (set to "production" to enforce secret validation)
APP_ENV=development

# LLM (commercial provider)
LLM_PROVIDER=auto
LLM_HTTP_TIMEOUT_S=30
LLM_SYSTEM_PROMPT=You are a factual assistant. Use citations and avoid unsupported claims.

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0.2

# Clause <-> Explanation pairing
WORKER_ENABLE_EXPLANATION_CHUNKS=1
HYBRID_ATTACH_EXPLANATION=1
HYBRID_EXPLANATION_PER_CLAUSE=1

# Worker table VL fallback (table OCR/repair)
WORKER_ENABLE_TABLE_VL_FALLBACK=1
WORKER_TABLE_VL_FALLBACK_DOC_TYPES=规范规程
WORKER_TABLE_VL_MAX_ITEMS_PER_DOC=20
WORKER_TABLE_VL_TIMEOUT_S=30
WORKER_TABLE_VL_MIN_CONFIDENCE=0.45
VL_PROVIDER=openai
VL_API_KEY=
VL_MODEL=gpt-4o-mini
VL_BASE_URL=https://api.openai.com/v1
VL_HTTP_TIMEOUT_S=30

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=1024

# Retrieval eval gate
EVAL_MIN_QUERIES=30
EVAL_MIN_HIT10=0.75
EVAL_MIN_MRR=0.45
EVAL_MIN_EVIDENCE_HIT10=0.80

# Postgres password (used in docker-compose)
POSTGRES_PASSWORD=CHANGE_ME_REQUIRED
